require 'base64'

# Authorization codes — randomised per session so players cannot share solutions
# Each pin must be distinct so the dual-auth panel cannot be solved with one shared code.
itsec_pin    = rand(1000..9999).to_s
clinical_pin = rand(1000..9999).to_s
clinical_pin = rand(1000..9999).to_s while clinical_pin == itsec_pin
backup_pin   = @random_pin    # Used by current MG-08 bedside pump placeholder lock
%>
