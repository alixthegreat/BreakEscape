# ============================================================================

# ERB Helper Methods
require 'base64'
require 'json'

def base64_encode(text)
  Base64.strict_encode64(text)
end

def json_escape(text)
  text.to_s.gsub('\\', '\\\\\\').gsub("\n", '\\n').gsub("\r", '\\r').gsub('"', '\\"')
end

