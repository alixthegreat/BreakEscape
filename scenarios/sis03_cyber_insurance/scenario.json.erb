    {
      "aimId": "access_evidence_archive",
      "title": "Access the Evidence Archive",
      "description": "Use the archive access code from Eleanor to enter the Evidence Archive. Review all three forensic evidence packets.",
      "status": "locked",
      "order": 2,
      "unlockCondition": { "aimCompleted": "investigate_claim" },
      "tasks": [
        {
          "taskId": "enter_archive",
          "type": "enter_room",
          "targetRoom": "meridian_evidence_archive",
          "status": "locked",
          "title": "Enter the Meridian Evidence Archive"
