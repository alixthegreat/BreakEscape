        {
          "taskId": "read_packet_a",
          "type": "manual",
          "status": "locked",
          "title": "Review Exhibit A — IT forensics summary"
        },
        {
          "taskId": "read_packet_b",
          "type": "manual",
          "status": "locked",
          "title": "Review Exhibit B — OT forensics summary (note the evidence gaps)"
        },
        {
          "taskId": "read_packet_c",
          "type": "manual",
          "status": "locked",
          "title": "Review Exhibit C — warranty compliance evidence"
        }
      ]
    },

    {
      "aimId": "assess_warranties",
      "title": "Assess Warranty Compliance",
      "description": "Talk to Eleanor Vance to go through the warranty positions. Assess W-03, W-07, W-09, and W-12 against the forensic evidence. The W-03 SIS patch position requires careful reasoning.",
      "status": "locked",
      "order": 3,
      "unlockCondition": { "aimCompleted": "access_evidence_archive" },
      "tasks": [
        {
          "taskId": "talk_to_eleanor_warranties",
          "type": "npc_conversation",
          "targetNPC": "eleanor_vance",
          "status": "locked",
          "title": "Discuss warranty compliance with Eleanor Vance"
        }
      ]
    },

    {
      "aimId": "make_recommendation",
      "title": "Review and Make Coverage Recommendation",
      "description": "Review the Osei loss adjustment report, open the NCSC attribution brief, and review the underwriting file. Then make your coverage recommendation to Eleanor.",
      "status": "locked",
      "order": 4,
      "unlockCondition": { "aimCompleted": "assess_warranties" },
      "tasks": [
        {
          "taskId": "read_osei_report",
          "type": "manual",
          "status": "locked",
          "title": "Review David Osei's independent loss adjustment report"
        },
        {
          "taskId": "read_ncsc_brief",
          "type": "manual",
          "status": "locked",
          "title": "Open and read the NCSC Attribution Brief (TLP:AMBER)"
        },
        {
          "taskId": "read_underwriting_file",
          "type": "manual",
          "status": "locked",
          "title": "Review the Meridian underwriting file — the renewal memo is critical"
        },
        {
          "taskId": "talk_to_eleanor_decision",
          "type": "npc_conversation",
          "targetNPC": "eleanor_vance",
          "status": "locked",
          "title": "Make your coverage recommendation to Eleanor Vance"
        }
      ]
    },

    {
      "aimId": "trent_water_assessment",
      "title": "Assess Trent Water Exposure (Optional)",
      "description": "Call Robert Ngata at the NCSC to discuss the Trent Water cross-sector exposure. Decide whether to include the third-party liability in scope or refer out pending investigation.",
      "status": "locked",
      "order": 5,
      "unlockCondition": { "globalVariable": "attribution_brief_reviewed", "equals": true },
      "tasks": [
        {
          "taskId": "assess_trent_water",
          "type": "npc_conversation",
          "targetNPC": "robert_ngata",
          "status": "locked",
          "title": "Call Robert Ngata (NCSC) — assess Trent Water third-party exposure"
        }
      ]
    },

    {
      "aimId": "closing_debrief",
      "title": "Closing Debrief — Insurance as Safety Governance",
      "description": "Eleanor Vance reviews the coverage decision and its implications for insurance as a safety governance mechanism. Topics vary based on what you found and what you decided.",
      "status": "locked",
      "order": 6,
      "unlockCondition": { "aimCompleted": "make_recommendation" },
      "tasks": [
        {
          "taskId": "talk_to_eleanor_debrief",
          "type": "npc_conversation",
          "targetNPC": "eleanor_vance",
          "status": "locked",
          "title": "Closing debrief with Eleanor Vance"
        }
      ]
    }
  ],

  "music": {
    "events": [
      {
        "trigger": "game_loaded",
        "condition": "!globalVars.briefing_played",
        "playlist": "cutscene",
        "fade": false
      },
      {
        "trigger": "game_loaded",
        "condition": "globalVars.briefing_played === true",
        "playlist": "noir",
        "fade": false
      },
      {
        "trigger": "global_variable_changed:briefing_played",
        "condition": "value === true",
        "playlist": "noir",
        "fade": true
      },
      {
        "trigger": "global_variable_changed:debrief_complete",
        "condition": "value === true",
        "playlist": "victory",
        "autoStop": true,
        "disableClose": true,
        "fade": true,
        "credits": [
          { "text": "COVERAGE DETERMINATION COMPLETE",                                                                        "style": "title" },
          { "text": "MERIDIAN CYBER INSURANCE — MC-2023-ALBE-007",                                                          "style": "subtitle" },

          { "text": "── CLAIM REVIEW ──",                                                                                    "style": "section-header" },
          { "text": "Policy verified: affirmative cyber clause confirmed — incident falls within insuring clause",            "style": "entry", "condition": "globalVars.policy_reviewed" },
          { "text": "Forensic chain: verified — cyber event causally linked to physical damage",                             "style": "entry", "condition": "globalVars.forensic_chain_verified" },
          { "text": "Evidence archive: reviewed — all three forensic exhibits examined",                                     "style": "entry", "condition": "globalVars.warranty_evidence_reviewed" },

          { "text": "── WARRANTY POSITIONS ──",                                                                              "style": "section-header" },
          { "text": "W-03 Patch Management: arguable — safety-constraint exception applies to deferral; compensating controls absent", "style": "entry", "condition": "globalVars.warranty_checklist_complete" },
          { "text": "W-07 IT/OT Segmentation: breached — remediation deadline expired 4 months before incident",            "style": "entry", "condition": "globalVars.warranty_checklist_complete" },
          { "text": "W-09 Access Control: breached — contractor account not deprovisioned 14 months post-departure",        "style": "entry", "condition": "globalVars.warranty_checklist_complete" },
          { "text": "W-12 MSP Security: likely breached — CastleTech OT monitoring scope gap",                              "style": "entry", "condition": "globalVars.warranty_checklist_complete" },

          { "text": "── SIS CLAIM SYNTHESIS ──",                                                                            "style": "section-header" },
          { "text": "CLAIM-INS-001: IT/OT segmentation operated as a coverage condition for safety-critical OT exposure",   "style": "entry", "condition": "globalVars.ins001_assessed" },
          { "text": "CLAIM-INS-003: safety-constrained SIS patch deferral remained acceptable only if compensating controls existed", "style": "entry", "condition": "globalVars.ins003_assessed" },
          { "text": "CLAIM-INS-008: GREYMANTLE attribution informed the decision but remained below the act-of-war threshold", "style": "entry", "condition": "globalVars.ins008_assessed" },
          { "text": "CLAIM-INS-009: Meridian's prior renewal knowledge constrained how aggressively coverage could be denied", "style": "entry", "condition": "globalVars.ins009_assessed" },

          { "text": "── COVERAGE DECISION ──",                                                                               "style": "section-header" },
          { "text": "Position A1: Full coverage accepted (£8.2M)",                                                          "style": "entry", "condition": "globalVars.coverage_decision === 'A1'" },
          { "text": "Position A2: Proportional coverage (approx. £6.1M)",                                                   "style": "entry", "condition": "globalVars.coverage_decision === 'A2'" },
          { "text": "Position A3: Coverage declined",                                                                       "style": "entry", "condition": "globalVars.coverage_decision === 'A3'" },
          { "text": "War exclusion: invoked under Section 5.4 LMA5567A",                                                    "style": "entry", "condition": "globalVars.war_exclusion_invoked === true" },
          { "text": "War exclusion: not invoked",                                                                            "style": "entry", "condition": "globalVars.war_exclusion_invoked !== true" },

          { "text": "── TRENT WATER ──",                                                                                     "style": "section-header" },
          { "text": "Trent Water: NCSC exposure assessed via Robert Ngata",                                                 "style": "entry", "condition": "globalVars.trent_water_assessed" },
          { "text": "Trent Water: included in coverage scope (est. £400K)",                                                 "style": "entry", "condition": "globalVars.trent_water_in_scope" },
          { "text": "Trent Water: referred out pending forensic findings",                                                   "style": "entry", "condition": "globalVars.coverage_decision_made && !globalVars.trent_water_in_scope" }
        ]
      }
    ]
  },

