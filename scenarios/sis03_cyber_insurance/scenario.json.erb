      "order": 0,
      "tasks": [
        {
          "taskId": "talk_to_eleanor_initial",
          "type": "npc_conversation",
          "targetNPC": "eleanor_vance",
          "status": "active",
          "title": "Receive initial briefing from Eleanor Vance"
        }
      ]
    },

    {
      "aimId": "investigate_claim",
      "title": "Confirm Coverage and Trace the Forensic Chain",
      "description": "Review the Albion policy binder to confirm the incident falls within the insuring clause. Use the Forensic Data Platform terminal to trace the causal chain from cyber event to physical damage.",
      "status": "locked",
      "order": 1,
      "unlockCondition": { "aimCompleted": "initial_briefing" },
      "tasks": [
        {
          "taskId": "read_policy_binder",
          "type": "manual",
          "status": "locked",
          "title": "Read the Albion policy binder — identify the insuring clause, warranty schedule, and act-of-war exclusion"
        },
        {
          "taskId": "read_claim_file",
          "type": "manual",
          "status": "locked",
          "title": "Review Whitworth's incident notification and £8.2M claim quantum"
        },
        {
          "taskId": "submit_forensic_flag",
          "type": "manual",
          "status": "locked",
          "title": "Verify the forensic causal chain on the FDP terminal"
        }
      ]
