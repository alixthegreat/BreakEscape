              "observations": "A fragment of classified documents"
            }
          ],
          "observations": "A locked briefcase containing important documents"
        },
        {
          "type": "suitcase",
          "id": "document_bag_5",
          "name": "Locked Bag",
          "takeable": false,
          "locked": true,
          "lockType": "key",
          "requires": "nonexistent_key",
          "keyPins": [38, 33, 28, 42, 35, 30],
          "difficulty": "hard",
          "contents": [
            {
              "type": "notes",
              "name": "Document Fragment 5",
              "takeable": true,
              "readable": true,
              "text": "Document Fragment 5\n\nFinal document recovered! Congratulations - you've mastered lockpicking!",
              "observations": "A fragment of classified documents"
            }
