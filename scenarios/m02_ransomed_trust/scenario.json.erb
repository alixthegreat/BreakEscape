#   Hallways connect: North (Reception ↔ Server Room) / South (IT ↔ Emergency Storage)
#   Emergency Equipment Storage (PIN safe with offline backup keys)
# ============================================================================

# ERB Helper Methods
require 'base64'

def base64_encode(text)
  Base64.strict_encode64(text)
end

# Narrative Content Variables
ransomware_note = "YOUR PATIENT RECORDS ARE ENCRYPTED. 47 PATIENTS ON LIFE SUPPORT. 12 HOURS OF BACKUP POWER. PAY 2.5 BTC OR WATCH THEM DIE. - RANSOMWARE INCORPORATED"

